# Copy to .env and fill in your values
EVOLUTION_BASE_URL=http://localhost:8080
EVOLUTION_API_KEY=your_secret_key_here
EVOLUTION_INSTANCE=marketing_instance
# Multiple WhatsApp numbers: comma-separated instance names (each gets 200/day limit)
# EVOLUTION_INSTANCES=number1,number2,support
EVOLUTION_INSTANCES=marketing_instance
FLASK_PORT=5001
DAILY_MESSAGE_LIMIT=200
BATCH_SIZE=30
BATCH_PAUSE_MIN=5
BATCH_PAUSE_MAX=10
MESSAGE_DELAY_MIN=4
MESSAGE_DELAY_MAX=9
BUSINESS_START_HOUR=9
BUSINESS_END_HOUR=21
TIMEZONE=Asia/Kolkata
DB_PATH=./data/marketing.db
YOUR_STORE_URL=https://yourstore.com
YOUR_PHONE=+91-XXXXXXXXXX

# AI auto-reply
AI_AUTOREPLY_ENABLED=false
OPENAI_API_KEY=
OPENAI_MODEL=gpt-5-mini
AI_AUTOREPLY_MAX_CONTEXT_MESSAGES=8
AI_BUSINESS_NAME=Your Business Name
AI_ASSISTANT_LANGUAGE=en
AI_SYSTEM_PROMPT=You are a professional WhatsApp business assistant. Reply briefly, clearly, and helpfully. Keep replies suitable for WhatsApp, avoid long paragraphs, do not invent pricing or policies, and ask a short follow-up question when needed.
